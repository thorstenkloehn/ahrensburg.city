@inject mvc.Services.ITenantService TenantService
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    var tenantId = TenantService.GetCurrentTenantId();
    var tenantTitle = Configuration[$"TenantConfig:{tenantId}:Title"] ?? "MeinCMS";
    var pageTitle = ViewData["Title"] ?? "Wiki";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle - @tenantTitle</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/mvc.styles.css" asp-append-version="true" />
    @* Tenant-spezifisches CSS, falls vorhanden *@
    <link rel="stylesheet" href="~/css/tenant-@(tenantId).css" asp-append-version="true" onerror="this.style.display='none'" />
</head>
<body class="tenant-@tenantId">
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Page" asp-action="Index">@tenantTitle</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Page" asp-action="Index">Startseite</a>
                        </li>
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-light">
        <div class="container d-flex justify-content-between align-items-center py-3">
            <div>
                &copy; 2026 erstellt mit <a href="https://github.com/thorstenkloehn/ahrensburg.city" class="text-muted text-decoration-underline">ahrensburg.city</a>
            </div>
            <nav>
                <ul class="list-inline mb-0">
                    <li class="list-inline-item">
                        <a class="text-muted text-decoration-none" href="/impressum">Impressum</a>
                    </li>
                    <li class="list-inline-item ms-3">
                        <a class="text-muted text-decoration-none" href="/datenschutz">Datenschutz</a>
                    </li>
                </ul>
            </nav>
        </div>
    </footer>
    <div id="cookieBanner" class="cookie-banner bg-dark text-white py-3 border-top" style="display: none; position: fixed; bottom: 0; width: 100%; z-index: 9999;">
        <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center">
            <div class="mb-2 mb-md-0 me-md-4">
                Diese Website verwendet Cookies, um die Nutzererfahrung zu verbessern. Weitere Informationen finden Sie in unserer 
                <a href="/datenschutz" class="text-info text-decoration-none">Datenschutzerklärung</a>.
            </div>
            <div class="d-flex gap-2">
                <button id="acceptCookies" class="btn btn-primary btn-sm px-4">Akzeptieren</button>
                <button id="declineCookies" class="btn btn-outline-light btn-sm px-4">Ablehnen</button>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
