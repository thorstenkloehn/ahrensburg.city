@model WikiArtikel

@{
    var latestVersion = Model?.Versionen?.OrderByDescending(v => v.Zeitpunkt).FirstOrDefault();
    ViewData["Title"] = Model?.Slug ?? ViewBag.UrlSlug;
}

<div class="wiki-content">
    @if (Model == null)
    {
        <div class="alert alert-info">
            <h4>Diese Seite existiert noch nicht.</h4>
            @if (User?.Identity?.IsAuthenticated ?? false)
            {
                <p>Möchten Sie die Seite <strong>@ViewBag.UrlSlug</strong> erstellen?</p>
                <a asp-controller="Page" asp-action="Neuformular" asp-route-slug="@ViewBag.UrlSlug" class="btn btn-success">Seite erstellen</a>
            }
            else
            {
                <p>Sie haben keine Berechtigung, diese Seite zu erstellen.</p>
            }
        </div>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>@Model.Slug</h1>
            <div>
                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="Page" asp-action="History" asp-route-slug="@Model.Slug" class="btn btn-outline-info btn-sm me-1">Historie</a>
                    <a asp-controller="Page" asp-action="Edit" asp-route-slug="@Model.Slug" class="btn btn-outline-primary btn-sm">Bearbeiten</a>
                }
            </div>
        </div>

        @if (ViewData["IsOldVersion"] != null)
        {
            <div class="alert alert-warning">
                <strong>Hinweis:</strong> Sie betrachten eine alte Version dieses Artikels. 
                <a asp-controller="Page" asp-action="Index" asp-route-slug="@Model.Slug" class="btn btn-link btn-sm p-0 mb-1">Zur aktuellen Version wechseln</a>
            </div>
        }

        <div class="markdown-body">
            @if (latestVersion != null)
            {
                @Html.Raw(latestVersion.HtmlInhalt)
            }
            else
            {
                <p><em>Kein Inhalt verfügbar.</em></p>
            }
        </div>

        @if (latestVersion != null)
        {
            <hr />
            <div class="mt-2">
                <strong>Kategorien:</strong>
                @if (latestVersion.Kategorie != null && latestVersion.Kategorie.Any())
                {
                    @foreach (var kat in latestVersion.Kategorie)
                    {
                        <a asp-controller="Page" asp-action="Kategorie" asp-route-kategorie="@kat" class="badge bg-info text-dark text-decoration-none me-1">@kat</a>
                    }
                }
                else
                {
                    <span class="text-muted italic">Keine</span>
                }
            </div>
            <div class="text-muted small mt-2">
                Zuletzt aktualisiert am @latestVersion.Zeitpunkt.ToString("dd.MM.yyyy HH:mm")
            </div>
        }
    }
</div>
