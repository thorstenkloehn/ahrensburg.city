@model WikiArtikel

<h2>Neue Seite erstellen: @ViewBag.UrlSlug</h2>

<form asp-action="Create" method="post">
    <input type="hidden" name="slug" value="@ViewBag.UrlSlug" />
    
    <div class="form-group mb-3">
        <label for="syntax">Syntax:</label>
        <select name="syntax" id="syntax" class="form-select" onchange="toggleSyntax()">
            <option value="markdown" selected>Markdown</option>
            <option value="mediawiki">MediaWiki</option>
        </select>
    </div>

    <div id="markdown-container" class="form-group">
        <label for="markdownInhalt">Inhalt (Markdown):</label>
        <textarea name="markdownInhalt" id="markdownInhalt" class="form-control" rows="15" placeholder="Geben Sie hier Ihren Markdown-Inhalt ein..."></textarea>
        <small class="text-muted">
            Kategorien können am Anfang des Markdowns per YAML definiert werden.
        </small>
    </div>

    <div id="mediawiki-container" class="form-group d-none">
        <label for="wikiTextInhalt">Inhalt (MediaWiki):</label>
        <textarea name="wikiTextInhalt" id="wikiTextInhalt" class="form-control" rows="15" placeholder="Geben Sie hier Ihren MediaWiki-Inhalt ein..."></textarea>
        <small class="text-muted">
            Unterstützt [[Link]], '''Fett''', ''Kursiv'', == Überschriften ==.
        </small>
    </div>

    <div class="form-group mt-3">
        <label for="kategorienRaw">Kategorien (kommagetrennt):</label>
        <input type="text" name="kategorienRaw" id="kategorienRaw" class="form-control" placeholder="z.B. Technik, Hilfe, News" />
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Erstellen</button>
        @{
            var encodedSlug = string.Join("/", ((string)ViewBag.UrlSlug).Split('/').Select(s => System.Net.WebUtility.UrlEncode(s)));
        }
        <a href="~/@encodedSlug" class="btn btn-secondary">Abbrechen</a>
    </div>
</form>

@section Scripts {
    <script>
        function toggleSyntax() {
            var syntax = document.getElementById('syntax').value;
            if (syntax === 'markdown') {
                document.getElementById('markdown-container').classList.remove('d-none');
                document.getElementById('mediawiki-container').classList.add('d-none');
            } else {
                document.getElementById('markdown-container').classList.add('d-none');
                document.getElementById('mediawiki-container').classList.remove('d-none');
            }
        }
    </script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
