@model WikiArtikel

@{
    var latestVersion = Model?.Versionen?.OrderByDescending(v => v.Zeitpunkt).FirstOrDefault();
    ViewData["Title"] = "Bearbeiten: " + (Model?.Slug ?? ViewBag.UrlSlug);
}

<h2>Seite bearbeiten: @Model.Slug</h2>

<form action="~/Edit/@Model.Slug" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="slug" value="@Model.Slug" />
    <div class="form-group">
        <label for="markdownInhalt">Inhalt (Markdown):</label>
        <textarea name="markdownInhalt" id="markdownInhalt" class="form-control" rows="15" placeholder="Geben Sie hier Ihren Markdown-Inhalt ein...">@(latestVersion?.MarkdownInhalt)</textarea>
    </div>
    <div class="form-group mt-2">
        <label for="kategorienRaw">Kategorien (kommagetrennt):</label>
        <input type="text" name="kategorienRaw" id="kategorienRaw" class="form-control" placeholder="z.B. Technik, Hilfe, Dokumentation" value="@(latestVersion != null ? string.Join(", ", latestVersion.Kategorie) : "")" />
    </div>
    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Speichern</button>
        <a href="~/@Model.Slug" class="btn btn-secondary">Abbrechen</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
