@model WikiArtikel

@{
    var latestVersion = Model?.Versionen?.OrderByDescending(v => v.Zeitpunkt).FirstOrDefault();
    ViewData["Title"] = "Bearbeiten: " + (Model?.Slug ?? ViewBag.UrlSlug);
}

<h2>Seite bearbeiten: @(Model?.Slug ?? ViewBag.UrlSlug)</h2>

<form asp-controller="Page" asp-action="Edit" asp-route-slug="@(Model?.Slug ?? ViewBag.UrlSlug)" method="post">
    @Html.AntiForgeryToken()
    <div class="form-group">
        <label for="markdownInhalt">Inhalt (Markdown):</label>
        <textarea name="markdownInhalt" id="markdownInhalt" class="form-control" rows="15" placeholder="Geben Sie hier Ihren Markdown-Inhalt ein...">@(latestVersion?.MarkdownInhalt)</textarea>
        <small class="text-muted">
            Kategorien können am Anfang des Markdowns per YAML definiert werden, z.B.:<br />
            <code>---<br />Kategorie: [Technik, Hilfe]<br />---</code>
        </small>
    </div>
    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Speichern</button>
        <a asp-controller="Page" asp-action="Index" asp-route-slug="@Model?.Slug" class="btn btn-secondary">Abbrechen</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
