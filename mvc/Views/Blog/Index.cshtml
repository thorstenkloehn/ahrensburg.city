@using mvc.Models
@model List<WikiArtikel>

@{
    ViewData["Title"] = "Blog";
}

<nav aria-label="breadcrumb">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/">Home</a></li>
    <li class="breadcrumb-item active" aria-current="page">Blog</li>
  </ol>
</nav>

<div class="blog-index">
    <div class="d-flex justify-content-between align-items-center">
        <h1>Blog</h1>
        @if (User.IsInRole("Admin"))
        {
            var defaultSlug = "Blog:" + DateTime.Now.ToString("yyyy-MM-dd_HH-mm");
            <a asp-controller="Page" asp-action="Neuformular" asp-route-slug="@defaultSlug" class="btn btn-success">Neuer Blog-Beitrag</a>
        }
    </div>
    <hr />

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">
            Es wurden keine Blog-Beiträge gefunden.
        </div>
    }
    else
    {
        <div class="list-group mt-4">
            @foreach (var artikel in Model)
            {
                var latestVersion = artikel.Versionen.FirstOrDefault();
                var encodedSlug = string.Join("/", artikel.Slug.Split('/').Select(s => System.Net.WebUtility.UrlEncode(s)));
                
                <a href="~/@encodedSlug" class="list-group-item list-group-item-action d-flex flex-column align-items-start mb-3 border rounded shadow-sm">
                    <div class="d-flex w-100 justify-content-between">
                        <h3 class="mb-1">@artikel.Slug.Replace("Blog:", "")</h3>
                        <small class="text-muted">@latestVersion?.Zeitpunkt.ToString("dd.MM.yyyy HH:mm") Uhr</small>
                    </div>
                    
                    @if (latestVersion != null)
                    {
                        <div class="mb-2 text-dark">
                            @{
                                var plainText = System.Text.RegularExpressions.Regex.Replace(latestVersion.HtmlInhalt ?? "", "<.*?>", String.Empty);
                                var snippet = plainText.Length > 200 ? plainText.Substring(0, 200) + "..." : plainText;
                            }
                            @snippet
                        </div>
                    }
                    
                    <div class="mt-auto d-flex justify-content-between align-items-center">
                        <div>
                            <span class="btn btn-primary btn-sm">Weiterlesen</span>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-controller="Page" asp-action="Edit" asp-route-slug="@artikel.Slug" class="btn btn-outline-secondary btn-sm ms-2">Bearbeiten</a>
                            }
                        </div>
                        @if (latestVersion?.Kategorie != null && latestVersion.Kategorie.Any())
                        {
                            <div>
                                @foreach (var kat in latestVersion.Kategorie)
                                {
                                    <span class="badge bg-light text-dark border me-1">@kat</span>
                                }
                            </div>
                        }
                    </div>
                </a>
            }
        </div>
    }

    <div class="mt-4">
        <a href="/" class="btn btn-secondary">Zurück zur Startseite</a>
    </div>
</div>
