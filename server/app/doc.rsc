gis;\nCREATE EXTENSION hstore;\nALTER TABLE geometry_columns OWNER TO _renderd;\nALTER TABLE spatial_ref_sys OWNER TO _renderd;\n\\q\nexit\n"}]}],"\n",["$","h3",null,{"children":"Mapnik Testen"}],"\n",["$","pre",null,{"children":["$","code",null,{"className":"language-bash","children":"python3\nimport mapnik\nexit()\n"}]}],"\n",["$","h3",null,{"children":"Stylesheet configuration"}],"\n",["$","pre",null,{"children":["$","code",null,{"className":"language-bash","children":"mkdir ~/src\ncd ~/src\ngit clone https://github.com/gravitystorm/openstreetmap-carto\ncd openstreetmap-carto\nsudo npm install -g carto\ncarto -v\ncarto project.mml > mapnik.xml\n"}]}],"\n",["$","h3",null,{"children":"Loading data"}],"\n",["$","pre",null,{"children":["$","code",null,{"className":"language-bash","children":"mkdir ~/data\ncd ~/data\nwget https://download.geofabrik.de/europe/germany/schleswig-holstein-latest.osm.pbf\nosmosis --read-pbf file=schleswig-holstein-latest.osm.pbf --bounding-box left=10.1141 right=10.3716 top=53.7136 bottom=53.6249 --write-pbf file=ahrensburg.pbf\n\nchmod o+rx ~\nsudo -u _renderd osm2pgsql -d gis --create --slim  -G --hstore --tag-transform-script ~/src/openstreetmap-carto/openstreetmap-carto.lua -C 2500 --number-processes 1 -S ~/src/openstreetmap-carto/openstreetmap-carto.style ~/data/ahrensburg.pbf\n"}]}],"\n",["$","h3",null,{"children":"Index erstellen"}],"\n",["$","pre",null,{"children":["$","code",null,{"className":"language-bash","children":"cd ~/src/openstreetmap-carto/\nsudo -u _renderd psql -d gis -f indexes.sql\n"}]}],"\n",["$","h3",null,{"children":"Shapefile download"}],"\n",["$","pre",null,{"children":["$","code",null,{"className":"language-bash","children":"cd ~/src/openstreetmap-carto/\nmkdir data\nsudo chown _renderd data\nsudo -u _renderd scripts/get-external-data.py\n"}]}],"\n",["$","h3",null,{"children":"Fonts"}],"\n",["$","pre",null,{"children":["$","code",null,{"className":"language-bash","children":"cd ~/src/openstreetmap-carto/\nscripts/get-fonts.sh\n"}]}],"\n",["$","h3",null,{"children":"Einstellung renderd"}],"\n",["$","pre",null,{"children":["$","code",null,{"className":"language-bash","children":"sudo nano /etc/renderd.conf\n"}]}],"\n",["$","pre",null,{"children":["$","code",null,{"className":"language-bash","children":"[s2o]\nURI=/hot/\nXML=/home/_renderd/src/openstreetmap-carto/mapnik.xml\nHOST=localhost\nTILESIZE=256\nMAXZOOM=20\n"}]}],"\n",["$","h3",null,{"children":"Making sure that you can see debug messages"}],"\n",["$","pre",null,{"children":["$","code",null,{"className":"language-bash","children":"sudo nano /usr/lib/systemd/system/renderd.service\n"}]}],"\n",["$","pre",null,{"children":["$","code",null,{"className":"language-bash","children":"sudo systemctl daemon-reload\nsudo systemctl restart renderd\nsudo systemctl restart apache2\n"}]}],"\n",["$","h3",null,{"children":"Apache2"}],"\n",["$","pre",null,{"children":["$","code",null,{"className":"language-bash","children":"sudo /etc/init.d/apache2 restart\n"}]}],"\n",["$","h3",null,{"children":"Apache2 Port ändern"}],"\n",["$","pre",null,{"children":["$","code",null,{"className":"language-bash","children":"sudo nano /etc/apache2/ports.conf\n"}]}],"\n",["$","pre",null,{"children":["$","code",null,{"className":"language-bash","children":"Listen 8080\n"}]}],"\n",["$","h3",null,{"children":"Apache2 Reatart"}],"\n",["$","pre",null,{"children":["$","code",null,{"className":"language-bash","children":"sudo /etc/init.d/apache2 restart\n"}]}],"\n",["$","h3",null,{"children":"ahrensburg.city Installieren"}],"\n",["$","pre",null,{"children":["$","code",null,{"className":"language-bash","children":"sudo apt-get install nginx\nsudo rm /etc/nginx/sites-enabled/default\nsudo systemctl stop nginx\nsudo snap install --classic certbot\nsudo ln -s /snap/bin/certbot /usr/bin/certbot\nsudo systemctl stop nginx\nsudo certbot certonly --standalone -d ahrensburg.city -d www.ahrensburg.city\nsudo certbot certonly --standalone -d karte.ahrensburg.city\n"}]}],"\n",["$","p",null,{"children":"Neuen Nutzer erstellen"}],"\n",["$","pre",null,{"children":["$","code",null,{"className":"language-bash","children":"sudo adduser thorsten\nsudo usermod -aG sudo thorsten\nexit\n"}]}],"\n",["$","h3",null,{"children":"ssh thorsten"}],"\n",["$","pre",null,{"children":["$","code",null,{"className":"language-bash","children":"ssh thorsten@\ncd $HOME\nsudo -u postgres -i\ncreateuser thorsten\ncreatedb -E UTF8 -O thorsten thorsten\npsql\n\\c thorsten\nCREATE EXTENSION postgis;\nCREATE EXTENSION hstore;\nALTER TABLE geometry_columns OWNER TO thorsten;\nALTER TABLE spatial_ref_sys OWNER TO thorsten;\n## Passwort für den Benutzer postgres setzen\n\\password thorsten\n\\q\nexit\n"}]}],"\n",["$","h3",null,{"children":"Herunterladen der Daten"}],"\n",["$","pre",null,{"children":["$","code",null,{"className":"language-bash","children":"cd $HOME\nwget https://download.geofabrik.de/europe/germany/schleswig-holstein-latest.osm.pbf\nosmosis --read-pbf file=schleswig-holstein-latest.osm.pbf --bounding-box left=10.1141 right=10.3716 top=53.7136 bottom=53.6249 --write-pbf file=ahrensburg.pbf\n\nosm2pgsql  -d thorsten --create  -G --hstore  ahrensburg.pbf\n"}]}],"\n",["$","h3",null,{"children":"Build von Ahrensburg.city"}],"\n",["$","pre",null,{"children":["$","code",null,{"className":"language-bash","children":"cd $HOME\ngit clone https://github.com/thorstenkloehn/ahrensburg.city.git\ncd ahrensburg.city\nnpm install\nnpm run build\n"}]}],"\n",["$","h2",null,{"children":"Systemctl Einrichten"}],"\n",["$","pre",null,{"children":["$","code",null,{"className":"language-bash","children":"sudo cp ahrensburg-city.service /etc/systemd/system/ahrensburg-city.service\nsudo systemctl enable ahrensburg-city\nsudo systemctl start ahrensburg-city\n"}]}],"\n",["$","h3",null,{"children":"config daten kopieren"}],"\n",["$","pre",null,{"children":["$","code",null,{"className":"language-bash","children":"cp env.local.example .env.local\nnano .env.local\n"}]}],"\n",["$","h2",null,{"children":"Restart"}],"\n",["$","pre",null,{"children":["$","code",null,{"className":"language-bash","children":"sudo cp ahrensburg-city.conf /etc/nginx/conf.d/ahrensburg-city.conf\nsudo systemctl restart ahrensburg-city\nsudo systemctl restart nginx\n"}]}]],null]]},[null,["$","div",null,{"className":"flex","children":[["$","div",null,{"className":"w-5/20","children":["$","ul",null,{"className":"flex flex-col space-y-1","children":[["$","li",null,{"children":["$","$L2",null,{"href":"/doc","children":"Server"}]}],["$","li",null,{"children":["$","$L2",null,{"href":"/doc/IDE","children":"IDE"}]}],["$","li",null,{"children":["$","$L2",null,{"href":"/doc/Server_Mieten","children":"Server Mieten"}]}],["$","li",null,{"children":["$","$L2",null,{"href":"/doc/Analysetool","children":"Analysetool"}]}],["$","li",null,{"children":["$","$L2",null,{"href":"/doc/Webentwicklung","children":"Webentwicklung"}]}]]}]}],["$","div",null,{"className":"flex-grow pl-7 w-full","children":["$","$L3",null,{"parallelRouterKey":"children","segmentPath":["children","doc","children"],"loading":"$undefined","loadingStyles":"$undefined","loadingScripts":"$undefined","hasLoading":false,"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L4",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined","styles":null}]}]]}],null]]},[null,["$","html",null,{"lang":"de","children":["$","body",null,{"children":["$","div",null,{"className":"container mx-auto","children":[[["$","nav",null,{"className":"flex md:flex hidden","children":["$","ul",null,{"className":"list-none flex flex-row","children":[["$","li",null,{"children":["$","$L2",null,{"href":"/","className":"text-blue-500","children":"Startseite"}]}],["$","li",null,{"children":["$","$L2",null,{"href":"/karte","className":"text-blue-500 p-4","children":"Karte"}]}],["$","li",null,{"children":["$","$L2",null,{"href":"/shop","className":"text-b